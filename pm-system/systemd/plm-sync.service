[Unit]
Description=Sync Designflow PLM master data (customers/licensors/properties/characters) into Directus
Wants=network-online.target
After=network-online.target docker.service

[Service]
Type=oneshot
User=ai
WorkingDirectory=/worksp/directus
EnvironmentFile=/home/ai/.plm-sync.env
ExecStart=/usr/bin/bash /worksp/directus/pm-system/run-plm-sync.sh
